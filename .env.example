# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to source control

# Google Sheets target spreadsheet ID (from the URL)
VITE_GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Your Vercel/Netlify deployment URL (no trailing slash)
VITE_API_BASE_URL=https://your-app.vercel.app

# --- SERVER-SIDE ONLY (Vercel environment variables — never in browser bundle) ---
# Paste the entire service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Supervisor PIN stored as bcrypt hash (never plain text)
# Generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('YOUR_PIN',10))"
SUPERVISOR_PIN_HASH=$2b$10$examplehashhere
